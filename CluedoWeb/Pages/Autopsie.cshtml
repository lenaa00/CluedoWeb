@page
@model CluedoWeb.Pages.AutopsieModel

<div class="autopsie-page">

    <div class="autopsie-bubble" aria-label="Dialogue du légiste">
        <p>2 indices sont sur la table d'autopsie.
            <br /> À vous de les analyser.</br></p>
    </div>

    <button class="hotspot-autopsie hotspot-fioles" type="button" onclick="ouvrirFioles()" aria-label="Analyser les fioles de sang">
        <span class="hotspot-label">🧪 Analyser les fioles</span>
    </button>

    <button class="hotspot-autopsie hotspot-lateralite" type="button" onclick="ouvrirLateralite()" aria-label="Analyser la blessure">
        <span class="hotspot-label">🔪 Étudier la blessure</span>
    </button>

    <a href="/Salle1" class="next-room-button autopsie-back" aria-label="Retour à la scène de crime">&#8592;</a>
    <a href="/SallesArmes" class="next-room-button autopsie-next" aria-label="Aller à la salle des armes">&#8594;</a>
</div>


<div id="fiolesModal" class="modal-autopsie hidden">
    <div class="modal-autopsie-content modal-fioles-enigme">
        <button class="modal-autopsie-close" type="button" onclick="fermerFioles()">&times;</button>

        <div class="autopsie-enigme-layout">
            <div class="autopsie-enigme-visuel">
                <div class="fioles-display" id="fiolesDisplay" aria-live="polite">
                    <div class="fiole-item" data-num="1" data-couleur="#c0392b" data-groupe="A-">
                        <div class="fiole-corps"><div class="fiole-liquide"></div></div>
                        <span class="fiole-numero">1</span>
                        <span class="fiole-groupe">A−</span>
                    </div>
                    <div class="fiole-item" data-num="2" data-couleur="#8e44ad" data-groupe="O+">
                        <div class="fiole-corps"><div class="fiole-liquide"></div></div>
                        <span class="fiole-numero">2</span>
                        <span class="fiole-groupe">O+</span>
                    </div>
                    <div class="fiole-item" data-num="3" data-couleur="#e67e22" data-groupe="AB+">
                        <div class="fiole-corps"><div class="fiole-liquide"></div></div>
                        <span class="fiole-numero">3</span>
                        <span class="fiole-groupe">AB+</span>
                    </div>
                    <div class="fiole-item" data-num="4" data-couleur="#1a5c2a" data-groupe="B+">
                        <div class="fiole-corps"><div class="fiole-liquide"></div></div>
                        <span class="fiole-numero">4</span>
                        <span class="fiole-groupe">B+</span>
                    </div>
                    <div class="fiole-item" data-num="5" data-couleur="#2471a3" data-groupe="A+">
                        <div class="fiole-corps"><div class="fiole-liquide"></div></div>
                        <span class="fiole-numero">5</span>
                        <span class="fiole-groupe">A+</span>
                    </div>
                    <div class="fiole-item" data-num="6" data-couleur="#7f8c8d" data-groupe="O-">
                        <div class="fiole-corps"><div class="fiole-liquide"></div></div>
                        <span class="fiole-numero">6</span>
                        <span class="fiole-groupe">O−</span>
                    </div>
                </div>

                <div class="fiole-consigne" id="fioleConsigne" aria-live="assertive">
                    <span id="fioleConsigneTexte">Mémorisez les fioles...</span>
                </div>
            </div>

            <div class="autopsie-enigme-panel">
                <h2>Échantillons sanguins</h2>
                <p>Le légiste a identifié le groupe sanguin de la victime : <strong class="groupe-cible">B+</strong>.<br>
                   Les fioles vont s'afficher brièvement, puis se cacher. Retrouvez la bonne.</p>

                <div id="fiolesPhase" class="fioles-phase">
                    <button class="autopsie-btn-lancer" type="button" id="btnLancerMemoire" onclick="lancerMemoire()">
                        ▶ Lancer le test mémoire
                    </button>
                </div>

                <form method="post" asp-page-handler="ValiderFiole" id="formFiole" class="fiole-choix-form hidden">
                    <p class="fiole-choix-label">Quelle fiole correspond au groupe <strong>B+</strong> ?</p>
                    <div class="fiole-choix-grille" role="group" aria-label="Choisir une fiole">
                        @for (int i = 1; i <= 6; i++)
                        {
                            <button type="submit"
                                    name="FioleChoisie"
                                    value="@i"
                                    class="fiole-choix-btn @(Model.FioleChoisie == i ? (Model.FioleValidee ? "is-correct" : "is-incorrect") : string.Empty)">
                                Fiole @i
                            </button>
                        }
                    </div>
                </form>

                @if (!string.IsNullOrWhiteSpace(Model.MessageFiole))
                {
                    <p class="autopsie-enigme-feedback @(Model.FioleValidee ? "feedback-ok" : "feedback-ko")">
                        @Model.MessageFiole
                    </p>
                }

                @if (Model.FioleValidee)
                {
                    <div class="revealed-autopsie-clue">
                        <h3>Indice confirmé</h3>
                        <p>La victime est bien identifiée. Son dossier médical indique un traitement récent pour une blessure au talon — une opération programmée il y a six mois.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


<div id="lateraliteModal" class="modal-autopsie hidden">
    <div class="modal-autopsie-content modal-lateralite-enigme">
        <button class="modal-autopsie-close" type="button" onclick="fermerLateralite()">&times;</button>

        <div class="autopsie-enigme-layout">
            <div class="autopsie-enigme-visuel">
                <div class="dos-schema" aria-label="Schéma du dos de la victime">
                    <div class="dos-silhouette">
                        <div class="dos-epaule dos-epaule-g"></div>
                        <div class="dos-tronc"></div>
                        <div class="dos-epaule dos-epaule-d"></div>
                        <div class="dos-blessure" aria-label="Blessure" title="Trajectoire de la blessure"></div>
                        <div class="dos-fleche" aria-hidden="true">&#8594;</div>
                    </div>
                    <p class="dos-legende">Vue dorsale — trajectoire de la plaie</p>
                </div>
            </div>

            <div class="autopsie-enigme-panel">
                <h2>Analyse de la blessure</h2>
                <p>La plaie dans le dos de la victime présente une trajectoire caractéristique.<br>
                   L'angle d'entrée et la direction du coup permettent de déterminer si le meurtrier est <strong>droitier</strong> ou <strong>gaucher</strong>.</p>

                <div class="lateralite-indices">
                    <div class="lateralite-indice-item">
                        <span class="indice-icone"></span>
                        <span>La plaie entre par la droite du dos de la victime et ressort vers la gauche.</span>
                    </div>
                    <div class="lateralite-indice-item">
                        <span class="indice-icone"></span>
                        <span>L'angle d'inclinaison est de ~35° vers le bas-gauche.</span>
                    </div>
                    <div class="lateralite-indice-item">
                        <span class="indice-icone">🩸</span>
                        <span>Le projections de sang indiquent un mouvement de l'attaquant de droite à gauche.</span>
                    </div>
                </div>

                <form method="post" asp-page-handler="ValiderLateralite" class="lateralite-form">
                    <p class="lateralite-question">Le meurtrier est-il <strong>droitier</strong> ou <strong>gaucher</strong> ?</p>
                    <div class="lateralite-choix" role="group" aria-label="Choisir la latéralité">
                        <button type="submit"
                                name="LateraliteChoisie"
                                value="droitier"
                                class="lateralite-btn @(Model.LateraliteChoisie == "droitier" ? (Model.LateraliteValidee ? "is-correct" : "is-incorrect") : string.Empty)">
                            <span class="lateralite-icone">✋</span>
                            <span class="lateralite-txt">Droitier</span>
                        </button>
                        <button type="submit"
                                name="LateraliteChoisie"
                                value="gaucher"
                                class="lateralite-btn @(Model.LateraliteChoisie == "gaucher" ? (Model.LateraliteValidee ? "is-correct" : "is-incorrect") : string.Empty)">
                            <span class="lateralite-icone">🤚</span>
                            <span class="lateralite-txt">Gaucher</span>
                        </button>
                    </div>
                </form>

                @if (!string.IsNullOrWhiteSpace(Model.MessageLateralite))
                {
                    <p class="autopsie-enigme-feedback @(Model.LateraliteValidee ? "feedback-ok" : "feedback-ko")">
                        @Model.MessageLateralite
                    </p>
                }

                @if (Model.LateraliteValidee)
                {
                    <div class="revealed-autopsie-clue">
                        <h3>Conclusion médicolégale</h3>
                        <p>Le meurtrier est <strong>gaucher</strong>. Croisez cet indice avec les suspects identifiés dans les autres pièces du manoir.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


<script>
    function ouvrirFioles() {
        document.getElementById('fiolesModal').classList.remove('hidden');
    }
    function fermerFioles() {
        document.getElementById('fiolesModal').classList.add('hidden');
    }
    function ouvrirLateralite() {
        document.getElementById('lateraliteModal').classList.remove('hidden');
    }
    function fermerLateralite() {
        document.getElementById('lateraliteModal').classList.add('hidden');
    }

    document.addEventListener('DOMContentLoaded', function () {
        ['fiolesModal', 'lateraliteModal'].forEach(function (id) {
            var modal = document.getElementById(id);
            modal.addEventListener('click', function (e) {
                if (e.target === modal) modal.classList.add('hidden');
            });
        });

        var ouvrirFiolesAuto = @Model.OuvrirFioles.ToString().ToLowerInvariant();
        var ouvrirLateraliteAuto = @Model.OuvrirLateralite.ToString().ToLowerInvariant();
        if (ouvrirFiolesAuto) ouvrirFioles();
        if (ouvrirLateraliteAuto) ouvrirLateralite();
    });

    var memoireEnCours = false;

    function lancerMemoire() {
        if (memoireEnCours) return;
        memoireEnCours = true;

        var btn = document.getElementById('btnLancerMemoire');
        var consigneTexte = document.getElementById('fioleConsigneTexte');
        var display = document.getElementById('fiolesDisplay');
        var formFiole = document.getElementById('formFiole');

        btn.disabled = true;
        btn.textContent = 'Mémorisation en cours...';

        appliquerCouleursFioles(true);
        consigneTexte.textContent = 'Mémorisez les couleurs et les groupes !';

        var temps = 4;
        var interval = setInterval(function () {
            temps--;
            consigneTexte.textContent = 'Mémorisez... ' + temps + 's';
            if (temps <= 0) {
                clearInterval(interval);
                cacherFioles();
            }
        }, 1000);
    }

    function appliquerCouleursFioles(visible) {
        var fioles = document.querySelectorAll('.fiole-item');
        fioles.forEach(function (fiole) {
            var liquide = fiole.querySelector('.fiole-liquide');
            var groupe = fiole.querySelector('.fiole-groupe');
            if (visible) {
                liquide.style.background = fiole.dataset.couleur;
                liquide.style.opacity = '1';
                groupe.style.opacity = '1';
                fiole.classList.add('visible');
            } else {
                liquide.style.background = '#555';
                liquide.style.opacity = '0.2';
                groupe.style.opacity = '0';
                fiole.classList.remove('visible');
            }
        });
    }

    function cacherFioles() {
        appliquerCouleursFioles(false);
        document.getElementById('fioleConsigneTexte').textContent = 'Les fioles sont cachées. Retrouvez le groupe B+.';
        document.getElementById('formFiole').classList.remove('hidden');
        document.getElementById('fiolesPhase').classList.add('hidden');
        memoireEnCours = false;
    }
</script>


<style>
:root {
    --acier:       #1c2a35;
    --acier-clair: #263545;
    --acier-bord:  #344d5e;
    --neon:        #4fc3f7;
    --neon-glow:   rgba(79, 195, 247, 0.35);
    --blanc-froid: #e8eef2;
    --gris-metal:  #8fa4b2;
    --rouge-sang:  #c0392b;
    --rouge-glow:  rgba(192, 57, 43, 0.5);
    --vert-ok:     #00c896;
    --vert-ok-bg:  rgba(0, 200, 150, 0.12);
    --rouge-ko:    #e74c3c;
    --rouge-ko-bg: rgba(231, 76, 60, 0.12);
    --texte:       #ccd8e0;
    --texte-dim:   #6e8a99;
    --font-mono:   'Courier New', Courier, monospace;
}

.hotspot-autopsie {
    position: absolute;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    cursor: pointer;
    background: rgba(28, 42, 53, 0.82);
    border: 1px solid var(--acier-bord);
    border-radius: 4px;
    color: var(--neon);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.65rem 1.1rem;
    box-shadow: 0 0 14px var(--neon-glow), inset 0 0 8px rgba(79,195,247,0.04);
    transition: box-shadow 0.25s ease, border-color 0.25s ease, background 0.2s ease;
    z-index: 10;
}
.hotspot-autopsie:hover {
    background: rgba(28, 42, 53, 0.97);
    border-color: var(--neon);
    box-shadow: 0 0 28px var(--neon-glow), 0 0 6px var(--neon-glow);
}
.hotspot-fioles     { top: 38%; left: 30%; transform: translateX(-50%); }
.hotspot-lateralite { top: 55%; left: 68%; transform: translateX(-50%); }

.autopsie-back {
    position: absolute;
    left: 4vw;
    bottom: 4vh;
    background: rgba(28,42,53,0.82) !important;
    border: 1px solid var(--acier-bord) !important;
    color: var(--neon) !important;
    box-shadow: 0 0 12px var(--neon-glow) !important;
}
.autopsie-back:hover {
    border-color: var(--neon) !important;
    box-shadow: 0 0 24px var(--neon-glow) !important;
    color: #fff !important;
    background: rgba(28,42,53,0.97) !important;
}

@@media (max-width: 768px) {
    .hotspot-fioles     { top: 32%; left: 28%; font-size: 0.72rem; padding: 0.5rem 0.8rem; }
    .hotspot-lateralite { top: 50%; left: 66%; font-size: 0.72rem; padding: 0.5rem 0.8rem; }
}

.modal-autopsie {
    position: fixed;
    inset: 0;
    background: rgba(5, 10, 14, 0.93);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
    overflow-y: auto;
    padding: 1rem;
    backdrop-filter: blur(4px);
}
.modal-autopsie.hidden { display: none; }

.modal-autopsie-content {
    position: relative;
    background: var(--acier);
    border: 1px solid var(--acier-bord);
    border-radius: 6px;
    padding: 2rem;
    box-shadow:
        0 0 0 1px rgba(79,195,247,0.08),
        0 30px 80px rgba(0,0,0,0.7),
        0 0 40px rgba(79,195,247,0.06);
    width: min(1080px, 94vw);
    max-height: 92vh;
    overflow-y: auto;
}

.modal-autopsie-content::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--neon), transparent);
    border-radius: 6px 6px 0 0;
}

.modal-autopsie-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: transparent;
    border: 1px solid var(--acier-bord);
    color: var(--gris-metal);
    font-size: 1.1rem;
    cursor: pointer;
    width: 32px;
    height: 32px;
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s, box-shadow 0.2s;
    font-family: var(--font-mono);
    line-height: 1;
}
.modal-autopsie-close:hover {
    border-color: var(--rouge-sang);
    color: var(--rouge-sang);
    box-shadow: 0 0 10px var(--rouge-glow);
}

.autopsie-enigme-layout {
    display: grid;
    grid-template-columns: minmax(200px, 280px) minmax(280px, 1fr);
    gap: 1.5rem;
    align-items: start;
}

.autopsie-enigme-visuel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    background: rgba(0,0,0,0.25);
    border: 1px solid var(--acier-bord);
    border-radius: 4px;
    padding: 1.2rem;
}

.autopsie-enigme-panel {
    background: var(--acier-clair);
    border: 1px solid var(--acier-bord);
    border-radius: 4px;
    padding: 1.5rem;
    color: var(--texte);
}
.autopsie-enigme-panel h2 {
    margin-top: 0;
    color: var(--neon);
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-bottom: 1px solid var(--acier-bord);
    padding-bottom: 0.6rem;
    margin-bottom: 1rem;
}
.autopsie-enigme-panel p { color: var(--texte); line-height: 1.6; }
.autopsie-enigme-panel strong { color: var(--blanc-froid); }

.autopsie-enigme-feedback {
    margin: 1rem 0 0;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    border-radius: 3px;
    padding: 0.65rem 0.9rem;
    border-left: 3px solid;
    letter-spacing: 0.03em;
}
.feedback-ok {
    background: var(--vert-ok-bg);
    color: var(--vert-ok);
    border-color: var(--vert-ok);
}
.feedback-ko {
    background: var(--rouge-ko-bg);
    color: var(--rouge-ko);
    border-color: var(--rouge-ko);
}

.revealed-autopsie-clue {
    margin-top: 1rem;
    padding: 1rem 1.1rem;
    border-radius: 3px;
    background: rgba(0, 200, 150, 0.07);
    border-left: 3px solid var(--vert-ok);
    box-shadow: 0 0 16px rgba(0,200,150,0.08);
}
.revealed-autopsie-clue h3 {
    margin: 0 0 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--vert-ok);
}
.revealed-autopsie-clue p { color: var(--texte); margin: 0; }

.fioles-display {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.9rem;
    width: 100%;
}

.fiole-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
}

.fiole-corps {
    width: 34px;
    height: 68px;
    border: 2px solid var(--acier-bord);
    border-radius: 3px 3px 6px 6px;
    position: relative;
    background: rgba(255,255,255,0.04);
    overflow: hidden;
    box-shadow: inset 0 0 6px rgba(0,0,0,0.4);
}

.fiole-corps::before {
    content: '';
    position: absolute;
    top: -11px;
    left: 50%;
    transform: translateX(-50%);
    width: 12px;
    height: 12px;
    border: 2px solid var(--acier-bord);
    border-bottom: none;
    background: transparent;
}

.fiole-liquide {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 62%;
    background: var(--gris-metal);
    opacity: 0.15;
    transition: background 0.35s ease, opacity 0.35s ease;
    border-radius: 0 0 4px 4px;
}

.fiole-numero {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--gris-metal);
    letter-spacing: 0.05em;
}

.fiole-groupe {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--neon);
    opacity: 0;
    transition: opacity 0.3s ease;
    text-shadow: 0 0 6px var(--neon-glow);
}
.fiole-item.visible .fiole-groupe { opacity: 1; }

.fiole-consigne {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--gris-metal);
    letter-spacing: 0.05em;
    min-height: 1.8rem;
}

.groupe-cible {
    color: var(--neon);
    text-shadow: 0 0 8px var(--neon-glow);
    font-family: var(--font-mono);
    font-size: 1.05rem;
}

.autopsie-btn-lancer {
    display: block;
    width: 100%;
    padding: 0.8rem 1rem;
    background: transparent;
    color: var(--neon);
    border: 1px solid var(--neon);
    border-radius: 3px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    margin-top: 1rem;
    box-shadow: 0 0 14px var(--neon-glow), inset 0 0 10px rgba(79,195,247,0.04);
    transition: box-shadow 0.2s ease, background 0.2s ease, color 0.2s ease;
}
.autopsie-btn-lancer:hover {
    background: rgba(79,195,247,0.08);
    box-shadow: 0 0 28px var(--neon-glow), 0 0 6px var(--neon-glow);
}
.autopsie-btn-lancer:disabled {
    opacity: 0.35;
    cursor: not-allowed;
    box-shadow: none;
}

.fiole-choix-label {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--gris-metal);
    margin-bottom: 0.75rem;
    text-transform: uppercase;
}

.fiole-choix-grille {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    margin-top: 0.5rem;
}

.fiole-choix-btn {
    padding: 0.6rem 0.4rem;
    border: 1px solid var(--acier-bord);
    border-radius: 3px;
    background: rgba(0,0,0,0.2);
    color: var(--texte);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, color 0.2s ease;
}
.fiole-choix-btn:hover {
    border-color: var(--neon);
    color: var(--neon);
    box-shadow: 0 0 10px var(--neon-glow);
}
.fiole-choix-btn.is-correct {
    border-color: var(--vert-ok);
    background: var(--vert-ok-bg);
    color: var(--vert-ok);
    box-shadow: 0 0 14px rgba(0,200,150,0.25);
}
.fiole-choix-btn.is-incorrect {
    border-color: var(--rouge-ko);
    background: var(--rouge-ko-bg);
    color: var(--rouge-ko);
    box-shadow: 0 0 14px rgba(231,76,60,0.2);
}

