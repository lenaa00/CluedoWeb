@page

<div class="salle1">
    <div class="salle1-text">
        <p>Oh vous voilà enfin !</p>
        <p>Nous pouvons démarrer l'enquête, <br />la scène de crime est à vous... </p>
    </div>
    
    <!-- Zone cliquable pour la blessure -->
    <button class="hotspot-blessure" onclick="showBlessure()"></button>
    
    <!-- Zone cliquable pour le tiroir -->
    <button class="hotspot-tiroir" onclick="showTiroir()"></button>
    
    <!-- Zone cliquable pour le tapis -->
    <button class="hotspot-tapis" onclick="showTapis()"></button>
</div>

<!-- Modal pour afficher l'image blessure -->
<div id="blessureModal" class="modal-blessure hidden">
    <div class="modal-blessure-content">
        <button class="modal-blessure-close" onclick="closeBlessure()">×</button>
        <img src="/images/blessure.png" alt="Blessure" />
    </div>
</div>

<!-- Modal pour afficher l'image tiroir -->
<div id="tiroirModal" class="modal-tiroir hidden">
    <div class="modal-tiroir-content">
        <button class="modal-tiroir-close" onclick="closeTiroir()">×</button>
        <img src="/images/scene de crime tiroir.png" alt="Tiroir" />
    </div>
</div>

<!-- Modal pour afficher l'image tapis -->
<div id="tapisModal" class="modal-tapis hidden">
    <div class="modal-tapis-content">
        <button class="modal-tapis-close" onclick="closeTapis()">×</button>
        <img src="/images/scene de crime lettre.png" alt="Tapis" />
    </div>
</div>

<script>
    function showBlessure() {
        document.getElementById('blessureModal').classList.remove('hidden');
    }
    
    function closeBlessure() {
        document.getElementById('blessureModal').classList.add('hidden');
    }
    
    function showTiroir() {
        document.getElementById('tiroirModal').classList.remove('hidden');
    }
    
    function closeTiroir() {
        document.getElementById('tiroirModal').classList.add('hidden');
    }
    
    function showTapis() {
        document.getElementById('tapisModal').classList.remove('hidden');
    }
    
    function closeTapis() {
        document.getElementById('tapisModal').classList.add('hidden');
    }
    
    // Fermer les modals en cliquant en dehors
    document.addEventListener('DOMContentLoaded', function() {
        const blessureModal = document.getElementById('blessureModal');
        const tiroirModal = document.getElementById('tiroirModal');
        const tapisModal = document.getElementById('tapisModal');
        
        blessureModal.addEventListener('click', function(e) {
            if (e.target === blessureModal) {
                closeBlessure();
            }
        });
        
        tiroirModal.addEventListener('click', function(e) {
            if (e.target === tiroirModal) {
                closeTiroir();
            }
        });
        
        tapisModal.addEventListener('click', function(e) {
            if (e.target === tapisModal) {
                closeTapis();
            }
        });
    });
</script>
