@page
@model CluedoWeb.Pages.Salle1Model
@using CluedoWeb.Pages

<div class="salle1">
    <div class="salle1-text">
        <p>Oh vous voila enfin !</p>
        <p>Nous pouvons démarrer l'enquête, <br />la scène de crime est à vous...</p>
    </div>

    <button class="hotspot-blessure" type="button" onclick="showBlessure()"></button>
    <button class="hotspot-tiroir" type="button" onclick="showTiroir()"></button>
    <button class="hotspot-tapis" type="button" onclick="showTapis()"></button>

    <a href="/Autopsie" class="next-room-button">&#8594;</a>
</div>

<!-- BLESSURE -->
<div id="blessureModal" class="modal-blessure hidden">
    <div class="modal-blessure-content">
        <button class="modal-blessure-close" onclick="closeBlessure()">&times;</button>
        <img src="/images/blessure.png" />
    </div>
</div>

<!-- TIROIR -->
<div id="tiroirModal" class="modal-tiroir hidden">
    <div class="modal-tiroir-content modal-tiroir-enigme">
        <button class="modal-tiroir-close" onclick="closeTiroir()">&times;</button>

        <!-- PANNEAU ENIGME -->
        <div id="tiroirEnigmePanel" class="tiroir-enigme-panel">
            <div class="tiroir-enigme-header">
                <span class="tiroir-enigme-icon">🔺</span>
                <div>
                    <h2 class="tiroir-enigme-title">Enigme du Tiroir</h2>
                    <p class="tiroir-enigme-subtitle">Chaque triangle cache un secret. Trouve la logique et complète le dernier.</p>
                </div>
            </div>

            <div class="triangles-container">

                <!-- Triangle 1 -->
                <div class="triangle-card" style="--delay:0s">
                    <div class="triangle-label">Exemple I</div>
                    <svg class="tri-svg" viewBox="0 0 200 180" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="triGrad1" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" style="stop-color:#3a1a0a;stop-opacity:1" />
                                <stop offset="100%" style="stop-color:#6b2f17;stop-opacity:1" />
                            </linearGradient>
                            <filter id="triFocus">
                                <feDropShadow dx="0" dy="4" stdDeviation="6" flood-color="rgba(0,0,0,0.45)" />
                            </filter>
                        </defs>
                        <polygon points="100,10 10,170 190,170" fill="url(#triGrad1)" filter="url(#triFocus)" stroke="#c8832a" stroke-width="2.5" />
                        <circle cx="100" cy="10" r="7" fill="#f5c96e" opacity="0.85"/>
                        <circle cx="10" cy="170" r="7" fill="#f5c96e" opacity="0.85"/>
                        <circle cx="190" cy="170" r="7" fill="#f5c96e" opacity="0.85"/>
                        <text x="100" y="38" text-anchor="middle" class="tri-val tri-top">2</text>
                        <text x="44" y="170" text-anchor="middle" class="tri-val tri-corner">2</text>
                        <text x="156" y="170" text-anchor="middle" class="tri-val tri-corner">3</text>
                        <rect x="72" y="95" width="56" height="34" rx="8" fill="rgba(0,0,0,0.45)" />
                        <text x="100" y="118" text-anchor="middle" class="tri-center">10</text>
                    </svg>
                </div>

                <!-- Triangle 2 -->
                <div class="triangle-card" style="--delay:0.15s">
                    <div class="triangle-label">Exemple II</div>
                    <svg class="tri-svg" viewBox="0 0 200 180" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="triGrad2" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" style="stop-color:#3a1a0a;stop-opacity:1" />
                                <stop offset="100%" style="stop-color:#6b2f17;stop-opacity:1" />
                            </linearGradient>
                        </defs>
                        <polygon points="100,10 10,170 190,170" fill="url(#triGrad2)" filter="url(#triFocus)" stroke="#c8832a" stroke-width="2.5" />
                        <circle cx="100" cy="10" r="7" fill="#f5c96e" opacity="0.85"/>
                        <circle cx="10" cy="170" r="7" fill="#f5c96e" opacity="0.85"/>
                        <circle cx="190" cy="170" r="7" fill="#f5c96e" opacity="0.85"/>
                        <text x="100" y="38" text-anchor="middle" class="tri-val tri-top">4</text>
                        <text x="44" y="170" text-anchor="middle" class="tri-val tri-corner">4</text>
                        <text x="156" y="170" text-anchor="middle" class="tri-val tri-corner">5</text>
                        <rect x="72" y="95" width="56" height="34" rx="8" fill="rgba(0,0,0,0.45)" />
                        <text x="100" y="118" text-anchor="middle" class="tri-center">36</text>
                    </svg>
                </div>

                <!-- Triangle 3 - à compléter -->
                <div class="triangle-card triangle-card--mystery" style="--delay:0.3s">
                    <div class="triangle-label">À toi de jouer !</div>
                    <svg class="tri-svg" viewBox="0 0 200 180" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="triGrad3" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" style="stop-color:#1a0a03;stop-opacity:1" />
                                <stop offset="100%" style="stop-color:#3d1a0c;stop-opacity:1" />
                            </linearGradient>
                            <filter id="glowFilter">
                                <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
                                <feMerge>
                                    <feMergeNode in="coloredBlur"/>
                                    <feMergeNode in="SourceGraphic"/>
                                </feMerge>
                            </filter>
                        </defs>
                        <polygon points="100,10 10,170 190,170" fill="url(#triGrad3)" filter="url(#triFocus)" stroke="#e8a030" stroke-width="3" />
                        <circle cx="100" cy="10" r="8" fill="#e8a030" filter="url(#glowFilter)" opacity="0.9" class="pulse-dot"/>
                        <circle cx="10" cy="170" r="8" fill="#e8a030" filter="url(#glowFilter)" opacity="0.9" class="pulse-dot"/>
                        <circle cx="190" cy="170" r="8" fill="#e8a030" filter="url(#glowFilter)" opacity="0.9" class="pulse-dot"/>
                        <text x="100" y="38" text-anchor="middle" class="tri-val tri-top">6</text>
                        <text x="44" y="170" text-anchor="middle" class="tri-val tri-corner">6</text>
                        <text x="156" y="170" text-anchor="middle" class="tri-val tri-corner">7</text>
                        <rect x="66" y="90" width="68" height="42" rx="10" fill="rgba(232,160,48,0.15)" stroke="#e8a030" stroke-width="1.5" stroke-dasharray="5,3" />
                        <text x="100" y="118" text-anchor="middle" class="tri-center tri-center--empty">?</text>
                    </svg>
                </div>

            </div>

            <!-- Zone de saisie — validation 100% JS, pas de <form> POST -->
            <div class="triangle-input-zone">
                <label class="triangle-input-label" for="triInput">Votre réponse :</label>
                <input id="triInput" class="triangle-input-field" type="number"
                       placeholder="???" min="1" max="999" autocomplete="off"
                       onkeydown="if(event.key==='Enter') validerTriangle()" />
                <button class="triangle-submit-btn" type="button" onclick="validerTriangle()">
                    <span>Valider</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </button>
            </div>

            <!-- Message erreur (caché par défaut) -->
            <div id="triangleFeedbackErreur" class="triangle-feedback triangle-feedback--error" style="display:none;">
                <span>✗</span>&nbsp; Mauvaise réponse... La logique t'échappe encore. Réessaie !
            </div>

            <!-- Indice -->
            <div class="triangle-hint">
                <span class="triangle-hint-icon">💡</span>
                <em>Indice : observe la relation entre les trois sommets et le centre de chaque triangle.</em>
            </div>
        </div>

        <!-- REVELATION (cachée par défaut) -->
        <div id="tiroirRevelationPanel" class="tiroir-revelation" style="display:none;">
            <div class="revelation-badge">
                <span class="revelation-check">✓</span>
                <span>Indice débloqué !</span>
            </div>
            <h2 class="revelation-title">Un objet dissimulé dans le tiroir</h2>
            <div class="revelation-image-wrapper">
                <img src="/images/scene de crime tiroir.png" class="revelation-img" alt="Scène de crime - tiroir" />
                <div class="revelation-overlay-label">📍 SCÈNE DE CRIME — TIROIR</div>
            </div>
            <div class="revelation-clue-box">
                <div class="revelation-clue-icon">🪵</div>
                <div>
                    <p class="revelation-clue-title">Indice découvert</p>
                    <p class="revelation-clue-text">Vous avez trouvé un <strong>manche en bois</strong> dissimulé sous des papiers froissés au fond du tiroir. L'extrémité porte des traces suspectes.</p>
                </div>
            </div>
        </div>

    </div>
</div>

<!-- TAPIS -->
<div id="tapisModal" class="modal-tapis hidden">
    <div class="modal-tapis-content modal-tapis-enigme">
        <button class="modal-tapis-close" onclick="closeTapis()">&times;</button>

        <div class="tapis-enigme-layout">
            <img src="/images/scene de crime lettre.png" />

            <div class="letter-enigme-panel">
                <h2>Lettre dechiree</h2>

                <form method="post" asp-page-handler="EnigmeLettre">
                    <div class="letter-sentence">
                        @foreach (var token in Model.LetterTokens)
                        {
                            if (token.EstMotMelange)
                            {
                                var classeEtat = token.EstCorrect == true ? "is-correct" : token.EstCorrect == false ? "is-incorrect" : "";

                                <label class="scrambled-word @classeEtat">
                                    <span>@token.Texte</span>
                                    <input type="text" name="@token.Champ" value="@token.Valeur" />
                                </label>
                            }
                            else
                            {
                                <span>@token.Texte</span>
                            }
                        }
                    </div>

                    <button type="submit">Verifier</button>
                </form>

                @if (Model.EnigmeReussie)
                {
                    <p>Lettre complete :</p>
                    <p>Tu vas payer pour le mal que tu m'as fais ! Je n'hesiterais pas a te planter mon talon dans le dos.</p>
                }
            </div>
        </div>
    </div>
</div>

<script>
    // ── BLESSURE ─────────────────────────────────────
    function showBlessure() { document.getElementById('blessureModal').classList.remove('hidden'); }
    function closeBlessure() { document.getElementById('blessureModal').classList.add('hidden'); }

    // ── TIROIR ───────────────────────────────────────
    var tiroirReussi = false; // mémorisé pour la durée de la session page

    function showTiroir() {
        var modal = document.getElementById('tiroirModal');
        modal.classList.remove('hidden');
        // Si déjà réussi, aller directement à la révélation
        if (tiroirReussi) { afficherRevelation(false); }
    }

    function closeTiroir() {
        document.getElementById('tiroirModal').classList.add('hidden');
    }

    function validerTriangle() {
        var input  = document.getElementById('triInput');
        var erreur = document.getElementById('triangleFeedbackErreur');
        var valeur = input.value.trim();

        if (!valeur) {
            secouInput(input);
            return;
        }

        if (valeur === '78') {
            tiroirReussi = true;
            erreur.style.display = 'none';
            afficherRevelation(true);
        } else {
            // Rester sur le modal, afficher l'erreur
            erreur.style.display = 'flex';
            secouInput(input);
            input.value = '';
            setTimeout(function() { input.focus(); }, 50);
        }
    }

    function afficherRevelation(avecAnimation) {
        document.getElementById('tiroirEnigmePanel').style.display = 'none';
        var rev = document.getElementById('tiroirRevelationPanel');
        rev.style.display = 'flex';
        if (avecAnimation) {
            rev.classList.remove('revelation-anim');
            void rev.offsetWidth;
            rev.classList.add('revelation-anim');
        }
    }

    function secouInput(el) {
        el.classList.add('tri-input-shake');
        setTimeout(function() { el.classList.remove('tri-input-shake'); }, 500);
    }

    // ── TAPIS ────────────────────────────────────────
    function showTapis() { document.getElementById('tapisModal').classList.remove('hidden'); }
    function closeTapis() { document.getElementById('tapisModal').classList.add('hidden'); }
</script>
