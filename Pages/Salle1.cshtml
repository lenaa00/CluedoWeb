@page
@model CluedoWeb.Pages.Salle1Model
@using CluedoWeb.Pages

<div class="salle1">
    <div class="salle1-text">
        <p>Oh vous voila enfin !</p>
        <p>Nous pouvons démarrer l'enquête, <br />la scène de crime est à vous...</p>
    </div>

    <button class="hotspot-blessure" type="button" onclick="showBlessure()"></button>
    <button class="hotspot-tiroir" type="button" onclick="showTiroir()"></button>
    <button class="hotspot-tapis" type="button" onclick="showTapis()"></button>


    <button id="nextRoomBtn" class="next-room-button next-room-button--locked" type="button" onclick="tentAccesAutopsie()">&#8594;</button>
</div>


<div id="blessureModal" class="modal-blessure hidden">
    <div class="modal-blessure-content modal-blessure-immersive">
        <button class="modal-blessure-close" onclick="closeBlessure()">&times;</button>

        <div class="blessure-header">
            <span class="blessure-header-icon">🔬</span>
            <div>
                <h2 class="blessure-header-title">Rapport Médico-Légal</h2>
                <p class="blessure-header-subtitle">Analyse préliminaire de la blessure — Scène de crime</p>
            </div>
        </div>

        <div class="blessure-layout">
            <div class="blessure-image-wrapper">
                <img src="/images/blessure.png" alt="Blessure de la victime" />
                <div class="blessure-image-label">📍 PIÈCE À CONVICTION — BLESSURE FATALE</div>
            </div>

            <div class="blessure-analyse">

                <div class="blessure-rapport-card">
                    <span class="blessure-rapport-icon"></span>
                    <div>
                        <p class="blessure-rapport-label">Type d'arme</p>
                        <p class="blessure-rapport-text">La blessure présente des bords nets et réguliers, caractéristiques d'une <strong>arme tranchante</strong>. La profondeur et la trajectoire de la plaie excluent tout instrument contondant.</p>
                    </div>
                </div>

                <div class="blessure-rapport-card">
                    <span class="blessure-rapport-icon"></span>
                    <div>
                        <p class="blessure-rapport-label">Angle de frappe</p>
                        <p class="blessure-rapport-text">L'inclinaison de la lésion indique une frappe <strong>légèrement descendante</strong>, cohérente avec un assaillant frappant depuis une position debout vers une victime partiellement agenouillée ou assise.</p>
                    </div>
                </div>

                <div class="blessure-taille-box">
                    <p class="blessure-taille-label">Stature estimée du meurtrier</p>
                    <p class="blessure-taille-value">1m60 — 1m80</p>
                    <p class="blessure-taille-sub">D'après l'angle et le niveau de la blessure</p>
                </div>

                <div class="blessure-rapport-card">
                    <span class="blessure-rapport-icon"></span>
                    <div>
                        <p class="blessure-rapport-label">Conclusion préliminaire</p>
                        <p class="blessure-rapport-text">Le profil de la blessure est <strong>cohérent avec une attaque intentionnelle</strong>. Des analyses complémentaires à la salle d'autopsie permettront de confirmer l'arme exacte utilisée.</p>
                    </div>
                </div>

            </div>
        </div>

        <div class="blessure-footer">
            <button class="blessure-close-btn" type="button" onclick="closeBlessureEtCollecte()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Indice enregistré — Fermer
            </button>
        </div>
    </div>
</div>


<div id="indicesOverlay" class="indices-collectes-overlay">
    <div class="indices-collectes-card">
        <div class="indices-check-circle">✓</div>
        <h2 class="indices-collectes-title">Indices collectés !</h2>
        <p class="indices-collectes-text">
            Vous avez analysé la blessure et établi le profil de l'assaillant.<br />
            La <strong style="color:#f5c96e;">Salle d'Autopsie</strong> est maintenant accessible.
        </p>
        <a href="/Autopsie" class="indices-unlock-badge">
            🔓&nbsp; Accéder à la Salle d'Autopsie
        </a>
    </div>
</div>


<div id="tiroirModal" class="modal-tiroir hidden">
    <div class="modal-tiroir-content modal-tiroir-enigme">
        <button class="modal-tiroir-close" onclick="closeTiroir()">&times;</button>

        <!-- PANNEAU ENIGME -->
        <div id="tiroirEnigmePanel" class="tiroir-enigme-panel">
            <div class="tiroir-enigme-header">
                <span class="tiroir-enigme-icon"></span>
                <div>
                    <h2 class="tiroir-enigme-title">Enigme du Tiroir</h2>
                    <p class="tiroir-enigme-subtitle">Chaque triangle cache un secret. Trouve la logique et complète le dernier.</p>
                </div>
            </div>

            <div class="triangles-container">

                <!-- Triangle 1 -->
                <div class="triangle-card" style="--delay:0s">
                    <div class="triangle-label">Exemple I</div>
                    <svg class="tri-svg" viewBox="0 0 200 180" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="triGrad1" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" style="stop-color:#3a1a0a;stop-opacity:1" />
                                <stop offset="100%" style="stop-color:#6b2f17;stop-opacity:1" />
                            </linearGradient>
                            <filter id="triFocus">
                                <feDropShadow dx="0" dy="4" stdDeviation="6" flood-color="rgba(0,0,0,0.45)" />
                            </filter>
                        </defs>
                        <polygon points="100,10 10,170 190,170" fill="url(#triGrad1)" filter="url(#triFocus)" stroke="#c8832a" stroke-width="2.5" />
                        <circle cx="100" cy="10" r="7" fill="#f5c96e" opacity="0.85"/>
                        <circle cx="10" cy="170" r="7" fill="#f5c96e" opacity="0.85"/>
                        <circle cx="190" cy="170" r="7" fill="#f5c96e" opacity="0.85"/>
                        <text x="100" y="38" text-anchor="middle" class="tri-val tri-top">2</text>
                        <text x="44" y="170" text-anchor="middle" class="tri-val tri-corner">2</text>
                        <text x="156" y="170" text-anchor="middle" class="tri-val tri-corner">3</text>
                        <rect x="72" y="95" width="56" height="34" rx="8" fill="rgba(0,0,0,0.45)" />
                        <text x="100" y="118" text-anchor="middle" class="tri-center">10</text>
                    </svg>
                </div>

                <!-- Triangle 2 -->
                <div class="triangle-card" style="--delay:0.15s">
                    <div class="triangle-label">Exemple II</div>
                    <svg class="tri-svg" viewBox="0 0 200 180" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="triGrad2" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" style="stop-color:#3a1a0a;stop-opacity:1" />
                                <stop offset="100%" style="stop-color:#6b2f17;stop-opacity:1" />
                            </linearGradient>
                        </defs>
                        <polygon points="100,10 10,170 190,170" fill="url(#triGrad2)" filter="url(#triFocus)" stroke="#c8832a" stroke-width="2.5" />
                        <circle cx="100" cy="10" r="7" fill="#f5c96e" opacity="0.85"/>
                        <circle cx="10" cy="170" r="7" fill="#f5c96e" opacity="0.85"/>
                        <circle cx="190" cy="170" r="7" fill="#f5c96e" opacity="0.85"/>
                        <text x="100" y="38" text-anchor="middle" class="tri-val tri-top">4</text>
                        <text x="44" y="170" text-anchor="middle" class="tri-val tri-corner">4</text>
                        <text x="156" y="170" text-anchor="middle" class="tri-val tri-corner">5</text>
                        <rect x="72" y="95" width="56" height="34" rx="8" fill="rgba(0,0,0,0.45)" />
                        <text x="100" y="118" text-anchor="middle" class="tri-center">36</text>
                    </svg>
                </div>

                
                <div class="triangle-card triangle-card--mystery" style="--delay:0.3s">
                    <div class="triangle-label">À toi de jouer !</div>
                    <svg class="tri-svg" viewBox="0 0 200 180" xmlns="http://www.w3.org/2000/svg">
                        <defs>
                            <linearGradient id="triGrad3" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" style="stop-color:#1a0a03;stop-opacity:1" />
                                <stop offset="100%" style="stop-color:#3d1a0c;stop-opacity:1" />
                            </linearGradient>
                            <filter id="glowFilter">
                                <feGaussianBlur stdDeviation="3" result="coloredBlur"/>
                                <feMerge>
                                    <feMergeNode in="coloredBlur"/>
                                    <feMergeNode in="SourceGraphic"/>
                                </feMerge>
                            </filter>
                        </defs>
                        <polygon points="100,10 10,170 190,170" fill="url(#triGrad3)" filter="url(#triFocus)" stroke="#e8a030" stroke-width="3" />
                        <circle cx="100" cy="10" r="8" fill="#e8a030" filter="url(#glowFilter)" opacity="0.9" class="pulse-dot"/>
                        <circle cx="10" cy="170" r="8" fill="#e8a030" filter="url(#glowFilter)" opacity="0.9" class="pulse-dot"/>
                        <circle cx="190" cy="170" r="8" fill="#e8a030" filter="url(#glowFilter)" opacity="0.9" class="pulse-dot"/>
                        <text x="100" y="38" text-anchor="middle" class="tri-val tri-top">6</text>
                        <text x="44" y="170" text-anchor="middle" class="tri-val tri-corner">6</text>
                        <text x="156" y="170" text-anchor="middle" class="tri-val tri-corner">7</text>
                        <rect x="66" y="90" width="68" height="42" rx="10" fill="rgba(232,160,48,0.15)" stroke="#e8a030" stroke-width="1.5" stroke-dasharray="5,3" />
                        <text x="100" y="118" text-anchor="middle" class="tri-center tri-center--empty">?</text>
                    </svg>
                </div>

            </div>

            <div class="triangle-input-zone">
                <label class="triangle-input-label" for="triInput">Votre réponse :</label>
                <input id="triInput" class="triangle-input-field" type="number"
                       placeholder="???" min="1" max="999" autocomplete="off"
                       onkeydown="if(event.key==='Enter') validerTriangle()" />
                <button class="triangle-submit-btn" type="button" onclick="validerTriangle()">
                    <span>Valider</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                </button>
            </div>

            <div id="triangleFeedbackErreur" class="triangle-feedback triangle-feedback--error" style="display:none;">
                <span>✗</span>&nbsp; Mauvaise réponse... La logique t'échappe encore. Réessaie !
            </div>

            <div class="triangle-hint">
                <span class="triangle-hint-icon">💡</span>
                <em>Indice : observe la relation entre les trois sommets et le centre de chaque triangle.</em>
            </div>
        </div>

       
        <div id="tiroirRevelationPanel" class="tiroir-revelation" style="display:none;">
            <div class="revelation-badge">
                <span class="revelation-check">✓</span>
                <span>Indice débloqué !</span>
            </div>
            <h2 class="revelation-title">Un objet dissimulé dans le tiroir</h2>
            <div class="revelation-image-wrapper">
                <img src="/images/scene de crime tiroir.png" class="revelation-img" alt="Scène de crime - tiroir" />
                <div class="revelation-overlay-label">📍 SCÈNE DE CRIME — TIROIR</div>
            </div>
            <div class="revelation-clue-box">
                <div class="revelation-clue-icon">🪵</div>
                <div>
                    <p class="revelation-clue-title">Indice découvert</p>
                    <p class="revelation-clue-text">Vous avez trouvé un <strong>manche en bois</strong> dissimulé sous des papiers froissés au fond du tiroir. L'extrémité porte des traces suspectes.</p>
                </div>
            </div>
        </div>

    </div>
</div>


<div id="tapisModal" class="modal-tapis hidden">
    <div class="modal-tapis-content modal-tapis-enigme">
        <button class="modal-tapis-close" onclick="closeTapis()">&times;</button>

        <div class="tapis-enigme-layout">
            <img src="/images/scene de crime lettre.png" alt="Lettre déchirée"
                 style="border-radius:12px;border:2px solid rgba(200,131,42,0.35);" />

           
            <div id="lettreEnigmePanel" class="letter-enigme-panel">
                <div class="letter-enigme-header">
                    <span class="letter-enigme-icon">✉️</span>
                    <div>
                        <h2>Lettre Déchirée</h2>
                        <p class="letter-enigme-subtitle">Les mots ont été brouillés. Remets-les dans le bon ordre pour reconstituer le message.</p>
                    </div>
                </div>

                <div class="letter-sentence">
                    <span>Tu</span>
                    <span>vas</span>
                    <label class="scrambled-word" id="sw-mot1">
                        <span>ypear</span>
                        <input id="lettre-mot1" type="text" placeholder="..." autocomplete="off"
                               onkeydown="if(event.key==='Enter') validerLettre()" />
                    </label>
                    <span>pour</span>
                    <span>le</span>
                    <label class="scrambled-word" id="sw-mot2">
                        <span>aml</span>
                        <input id="lettre-mot2" type="text" placeholder="..." autocomplete="off"
                               onkeydown="if(event.key==='Enter') validerLettre()" />
                    </label>
                    <span>que</span>
                    <span>tu</span>
                    <span>m'as</span>
                    <span>fais</span>
                    <span>!</span>
                    <span>Je</span>
                    <span>n'hesiterais</span>
                    <span>pas</span>
                    <span>a</span>
                    <span>te</span>
                    <label class="scrambled-word" id="sw-mot3">
                        <span>ltarepn</span>
                        <input id="lettre-mot3" type="text" placeholder="..." autocomplete="off"
                               onkeydown="if(event.key==='Enter') validerLettre()" />
                    </label>
                    <span>mon</span>
                    <label class="scrambled-word" id="sw-mot4">
                        <span>lanot</span>
                        <input id="lettre-mot4" type="text" placeholder="..." autocomplete="off"
                               onkeydown="if(event.key==='Enter') validerLettre()" />
                    </label>
                    <span>dans</span>
                    <span>le</span>
                    <span>dos.</span>
                </div>

                <div class="letter-enigme-actions">
                    <button type="button" class="letter-enigme-button" onclick="validerLettre()">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        Vérifier
                    </button>
                </div>

                <div id="lettreFeedbackErreur" class="letter-enigme-feedback" style="display:none;">
                    <span>✗</span>&nbsp; Certains mots sont incorrects. Réessaie !
                </div>

                <div class="letter-hint">
                    <span>💡</span>
                    <em>Indice : les mots mélangés contiennent les mêmes lettres que la solution, simplement réordonnées.</em>
                </div>
            </div>

           
            <div id="lettreRevelationPanel" class="tiroir-revelation" style="display:none;">
                <div class="revelation-badge">
                    <span class="revelation-check">✓</span>
                    <span>Message déchiffré !</span>
                </div>
                <h2 class="revelation-title">La lettre reconstituée</h2>
                <div class="revelation-clue-box" style="max-width:100%;">
                    <div class="revelation-clue-icon">✉️</div>
                    <div>
                        <p class="revelation-clue-title">Message original</p>
                        <p class="revelation-clue-text" style="font-style:italic;">
                            Tu vas <strong>payer</strong> pour le <strong>mal</strong> que tu m'as fais !
                            Je n'hesiterais pas a te <strong>planter</strong> mon <strong>talon</strong> dans le dos.
                        </p>
                    </div>
                </div>
                <div class="revelation-clue-box" style="max-width:100%; margin-top:0.75rem;">
                    <div class="revelation-clue-icon">🔍</div>
                    <div>
                        <p class="revelation-clue-title">Interprétation</p>
                        <p class="revelation-clue-text">La victime avait un <strong>ennemi juré</strong>. Ce message de menace suggère un mobile personnel et prémédité.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
   
    var blessureVue = false;

   
    function showBlessure() {
        document.getElementById('blessureModal').classList.remove('hidden');
    }

    function closeBlessure() {
        document.getElementById('blessureModal').classList.add('hidden');
    }

    function closeBlessureEtCollecte() {
        document.getElementById('blessureModal').classList.add('hidden');

        if (!blessureVue) {
            blessureVue = true;

          
            var overlay = document.getElementById('indicesOverlay');
            overlay.classList.add('active');

          
            var btn = document.getElementById('nextRoomBtn');
            btn.classList.remove('next-room-button--locked');
            btn.classList.add('next-room-button--unlocked');
            btn.onclick = function () { window.location.href = '/Autopsie'; };
        }
    }

    document.getElementById('indicesOverlay').addEventListener('click', function (e) {
        if (e.target === this) { this.classList.remove('active'); }
    });

   
    function tentAccesAutopsie() {
        if (!blessureVue) {
            var btn = document.getElementById('nextRoomBtn');
            btn.classList.add('next-room-button--shake');
            setTimeout(function () { btn.classList.remove('next-room-button--shake'); }, 500);
        }
    }

   
    var tiroirReussi = false;

    function showTiroir() {
        document.getElementById('tiroirModal').classList.remove('hidden');
        if (tiroirReussi) { afficherRevelation(false); }
    }

    function closeTiroir() {
        document.getElementById('tiroirModal').classList.add('hidden');
    }

    function validerTriangle() {
        var input  = document.getElementById('triInput');
        var erreur = document.getElementById('triangleFeedbackErreur');
        var valeur = input.value.trim();

        if (!valeur) { secouInput(input); return; }

        if (valeur === '78') {
            tiroirReussi = true;
            erreur.style.display = 'none';
            afficherRevelation(true);
        } else {
            erreur.style.display = 'flex';
            secouInput(input);
            input.value = '';
            setTimeout(function () { input.focus(); }, 50);
        }
    }

    function afficherRevelation(avecAnimation) {
        document.getElementById('tiroirEnigmePanel').style.display = 'none';
        var rev = document.getElementById('tiroirRevelationPanel');
        rev.style.display = 'flex';
        if (avecAnimation) {
            rev.classList.remove('revelation-anim');
            void rev.offsetWidth;
            rev.classList.add('revelation-anim');
        }
    }

    function secouInput(el) {
        el.classList.add('tri-input-shake');
        setTimeout(function () { el.classList.remove('tri-input-shake'); }, 500);
    }

  
    var lettreReussie = false;

    function showTapis() {
        document.getElementById('tapisModal').classList.remove('hidden');
        if (lettreReussie) { afficherRevelationLettre(false); }
    }

    function closeTapis() {
        document.getElementById('tapisModal').classList.add('hidden');
    }

    function normaliserMot(s) {
        
        return s.trim().toLowerCase()
            .normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    }

    function validerLettre() {
        var solutions = { 'lettre-mot1': 'payer', 'lettre-mot2': 'mal', 'lettre-mot3': 'planter', 'lettre-mot4': 'talon' };
        var swIds     = { 'lettre-mot1': 'sw-mot1', 'lettre-mot2': 'sw-mot2', 'lettre-mot3': 'sw-mot3', 'lettre-mot4': 'sw-mot4' };
        var erreur    = document.getElementById('lettreFeedbackErreur');
        var toutCorrect = true;

        for (var id in solutions) {
            var input = document.getElementById(id);
            var sw    = document.getElementById(swIds[id]);
            var val   = normaliserMot(input.value);
            var sol   = solutions[id];

            sw.classList.remove('is-correct', 'is-incorrect');
            if (val === sol) {
                sw.classList.add('is-correct');
            } else {
                sw.classList.add('is-incorrect');
                toutCorrect = false;
            }
        }

        if (toutCorrect) {
            lettreReussie = true;
            erreur.style.display = 'none';
            afficherRevelationLettre(true);
        } else {
            erreur.style.display = 'flex';
        }
    }

    function afficherRevelationLettre(avecAnimation) {
        document.getElementById('lettreEnigmePanel').style.display = 'none';
        var rev = document.getElementById('lettreRevelationPanel');
        rev.style.display = 'flex';
        if (avecAnimation) {
            rev.classList.remove('revelation-anim');
            void rev.offsetWidth;
            rev.classList.add('revelation-anim');
        }
    }
</script>
